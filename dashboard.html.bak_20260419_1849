  function maybeNotifyTicketAlerts(alerts, dateIso) {
    if (!ticketAlertsEnabled || !isMobileAlertContext() || !("Notification" in window)) return;
    if (Notification.permission !== "granted") return;
    if (!alerts.length) return;
    const signature = ticketAlertsSignature(alerts, dateIso);
    if (signature === lastTicketAlertSignature) return;
    lastTicketAlertSignature = signature;

    if (navigator.vibrate) {
      navigator.vibrate([120, 60, 120]);
    }

    const top = alerts.slice(0, 3).map(a => `${a.item.reunion} ${a.item.course} ${a.item.selection.num}-${a.item.selection.nom}`).join(" | ");
    new Notification("PMU Moulinette - tickets à jouer", {
      body: top,
      tag: signature,
      silent: false,
    });
  }

  async function enableTicketAlerts() {
    if (!isMobileAlertContext()) {
