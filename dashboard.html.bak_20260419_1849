<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate, max-age=0">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <title>PMU Moulinette</title>
  <style>
    :root {
      --bg: #f4f1ea;
      --panel: #fbf8f2;
      --card: #fffdf8;
      --border: #d8cfbf;
      --accent: #0f766e;
      --green: #2f855a;
      --red: #c53030;
      --orange: #c77d18;
      --text: #231c17;
      --muted: #786b5d;
      --radius: 16px;
      --shadow: 0 12px 28px rgba(52, 36, 18, 0.08);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background:
        radial-gradient(circle at top left, rgba(199,125,24,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(15,118,110,0.10), transparent 24%),
        var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      padding: 18px 32px;
      box-shadow: var(--shadow);
    }
    header h1 { font-size: 1.45rem; font-weight: 700; color: var(--text); }
    header p  { font-size: 0.82rem; color: var(--muted); margin-top: 3px; }
    .header-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .top-tabs {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      margin-top: 2px;
    }
    .top-tab {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 14px;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text);
      text-decoration: none;
      font-size: 0.82rem;
      font-weight: 700;
      transition: transform 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    }
    .top-tab:hover {
      transform: translateY(-1px);
      border-color: var(--accent);
      color: var(--accent);
    }
    .top-tab.active {
      background: rgba(15,118,110,0.10);
      border-color: rgba(15,118,110,0.30);
      color: var(--accent);
    }

    /* ── LAYOUT ── */
    .layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 20px;
      padding: 24px;
      max-width: 1400px;
      margin: 0 auto;
    }

    /* ── SIDEBAR ── */
    .sidebar { display: flex; flex-direction: column; gap: 16px; }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .card-title {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 14px 18px 10px;
      border-bottom: 1px solid var(--border);
    }
    .card-body { padding: 16px 18px; }

    /* ── DATE PICKER ── */
    .date-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .date-nav button {
      background: #fff;
      border: 1px solid var(--border);
      color: var(--text);
      width: 32px; height: 32px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .date-nav button:hover { background: var(--border); }
    #selected-date-label { font-size: 0.92rem; font-weight: 700; color: var(--text); }

    input[type="date"] {
      width: 100%;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 0.9rem;
      padding: 9px 12px;
      cursor: pointer;
      outline: none;
      margin-bottom: 12px;
    }
    input[type="date"]:focus { border-color: var(--accent); }
    input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.6); cursor: pointer; }

    /* ── QUICK DATES ── */
    .quick-btns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      margin-bottom: 0;
    }
    .quick-btn {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 0.78rem;
      padding: 7px 6px;
      cursor: pointer;
      text-align: center;
      transition: all 0.15s;
      font-weight: 500;
    }
    .quick-btn:hover   { border-color: var(--accent); color: var(--accent); }
    .quick-btn.active  { border-color: var(--accent); background: rgba(15,118,110,0.10); color: var(--accent); }

    /* ── ACTION BUTTONS ── */
    .action-btn {
      width: 100%;
      border: none;
      border-radius: 10px;
      padding: 13px 16px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .action-btn:last-child { margin-bottom: 0; }
    .action-btn:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
    .action-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .btn-import  { background: #174e9e; color: #fff; }
    .btn-analyse { background: #dff5ea; color: #17462f; border: 1px solid rgba(47,133,90,0.18); }
    .btn-gains   { background: #f9ead7; color: #6a3d00; border: 1px solid rgba(199,125,24,0.18); }
    .btn-all     { background: linear-gradient(135deg, #0f766e, #c77d18); color: #fff; }

    /* ── MULTI-DATE ── */
    .multi-toggle {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 12px;
      cursor: pointer;
    }
    .multi-toggle input { accent-color: var(--accent); cursor: pointer; }
    .multi-section { display: none; }
    .multi-section.visible { display: block; }
    .multi-row { display: flex; gap: 8px; align-items: center; margin-bottom: 10px; }
    .multi-row label { font-size: 0.78rem; color: var(--muted); min-width: 34px; }
    .multi-row input[type="date"] { margin-bottom: 0; flex: 1; }
    .multi-info {
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 10px;
      line-height: 1.4;
    }

    /* ── STATUS ── */
    #statusBox {
      font-size: 0.78rem;
      color: var(--muted);
      padding: 10px 14px;
      background: #fff;
      border-radius: 8px;
      min-height: 36px;
      line-height: 1.5;
      border: 1px solid var(--border);
    }

    /* ── PROGRESS ── */
    .progress-wrap { margin-bottom: 6px; display: none; }
    .progress-bar {
      height: 4px;
      background: var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: var(--accent);
      border-radius: 4px;
      transition: width 0.4s ease;
      width: 0%;
    }
    .progress-label {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 5px;
      text-align: right;
    }

    /* ── MAIN CONTENT ── */
    .main-col { display: flex; flex-direction: column; gap: 16px; }
    .hero-card {
      background: linear-gradient(135deg, rgba(255,255,255,.78), rgba(255,248,239,.92));
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow);
      padding: 24px 26px;
    }
    .hero-kicker {
      font-size: .76rem;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 8px;
    }
    .hero-card h2 {
      font-size: 1.7rem;
      line-height: 1.08;
      margin-bottom: 8px;
    }
    .hero-card p {
      color: var(--muted);
      font-size: .94rem;
      max-width: 760px;
      line-height: 1.5;
    }
    .version-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 12px;
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(15,118,110,0.22);
      background: rgba(15,118,110,0.08);
      color: var(--accent);
      font-size: 0.76rem;
      font-weight: 700;
    }
    .version-badge.is-active {
      background: rgba(47,133,90,0.12);
      border-color: rgba(47,133,90,0.30);
      color: var(--green);
    }
    .main-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(300px, .8fr);
      gap: 16px;
      align-items: start;
    }
    .primary-col,
    .side-col {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ── SUMMARY GRID ── */
    #summary {
      display: none;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }
    .box {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px 16px;
      box-shadow: var(--shadow);
    }
    .box .k { font-size: 0.72rem; color: var(--muted); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.6px; }
    .box .v { font-size: 1.25rem; font-weight: 700; color: var(--text); }

    /* ── RESULTS ── */
    #results { display: flex; flex-direction: column; gap: 12px; }

    .result-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .result-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 18px;
      border-bottom: 1px solid var(--border);
    }
    .result-head .title { font-size: 0.9rem; font-weight: 600; color: var(--text); }
    .result-card .status { padding: 12px 18px; font-size: 0.82rem; color: var(--muted); line-height: 1.6; }
    .result-card .meta {
      display: flex; gap: 8px; flex-wrap: wrap;
      padding: 12px 18px;
      border-bottom: 1px solid var(--border);
    }
    .result-card .meta .box { padding: 8px 12px; flex: 1; min-width: 100px; }
    .result-card .meta .box .v { font-size: 0.95rem; }

    /* ── PILL ── */
    .pill {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .pill.ok   { background: rgba(62,207,142,0.15); color: var(--green); }
    .pill.warn { background: rgba(246,173,85,0.15);  color: var(--orange); }
    .pill.no   { background: rgba(245,101,101,0.15); color: var(--red); }

    .section-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 18px 20px 12px;
      border-bottom: 1px solid rgba(216,207,191,.8);
    }
    .section-head h2 {
      font-size: 1rem;
      color: var(--text);
      margin-bottom: 3px;
    }
    .section-head p {
      font-size: 0.82rem;
      color: var(--muted);
    }
    .ghost-btn {
      background: #fff;
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 999px;
      padding: 9px 14px;
      font-size: 0.8rem;
      font-weight: 700;
      cursor: pointer;
    }
    .chip-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      padding: 14px 20px 0;
    }
    .chip-filter {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.76rem;
      font-weight: 700;
      color: var(--muted);
      cursor: pointer;
    }
    .chip-filter.active {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(15,118,110,0.08);
    }
    .full-day-group {
      margin: 14px 20px 18px;
      border: 1px solid rgba(216,207,191,.85);
      border-radius: 16px;
      overflow: hidden;
      background: rgba(255,255,255,0.65);
    }
    .full-day-group-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border-bottom: 1px solid rgba(216,207,191,.65);
      background: rgba(15,118,110,0.035);
    }
    .full-day-group-head h3 {
      font-size: 0.9rem;
      color: var(--text);
      margin-bottom: 3px;
    }
    .full-day-group-head p {
      font-size: 0.77rem;
      color: var(--muted);
    }
    .course-row.upcoming {
      background: rgba(15,118,110,0.05);
    }
    .course-row.played {
      opacity: 0.82;
    }
    .course-row.upcoming td:first-child {
      font-weight: 700;
      color: var(--accent);
    }
    .mobile-dock {
      display: none;
    }
    .urgent-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 12px;
      padding: 18px 20px 20px;
    }
    .urgent-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
    }
    .urgent-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }
    .urgent-title { font-size: 0.92rem; font-weight: 700; color: var(--text); }
    .urgent-sub { font-size: 0.8rem; color: var(--muted); margin-top: 3px; }
    .count-badge {
      background: rgba(199,125,24,0.12);
      color: var(--orange);
      border-radius: 999px;
      padding: 6px 10px;
      font-size: 0.74rem;
      font-weight: 700;
      white-space: nowrap;
    }
    .ticket-btn {
      margin-top: 12px;
      background: rgba(15,118,110,0.10);
      color: var(--accent);
      border: 1px solid rgba(15,118,110,0.18);
      border-radius: 12px;
      padding: 8px 12px;
      font-size: 0.78rem;
      font-weight: 700;
      cursor: default;
      display: inline-block;
    }
    .alert-card {
      background: linear-gradient(135deg, rgba(15,118,110,0.10), rgba(199,125,24,0.08));
      border: 1px solid rgba(15,118,110,0.18);
      border-radius: 18px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .alert-card .section-head { background: rgba(255,255,255,0.55); }
    .alert-list {
      display: grid;
      gap: 10px;
      padding: 14px 20px 20px;
    }
    .alert-item {
      background: rgba(255,255,255,0.8);
      border: 1px solid rgba(216,207,191,.9);
      border-radius: 14px;
      padding: 12px 14px;
    }
    .alert-item-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 8px;
    }
    .alert-item-title {
      font-size: 0.92rem;
      font-weight: 800;
      color: var(--text);
    }
    .alert-item-sub {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 4px;
      line-height: 1.35;
    }
    .alert-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 10px;
    }
    .alert-actions .ticket-btn {
      margin-top: 0;
    }
    .empty-state {
      padding: 18px 20px 20px;
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.5;
    }
    .muted-note {
      padding: 0 20px 18px;
      color: var(--muted);
      font-size: 0.78rem;
    }
    .state-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 18px 20px 20px;
    }
    .state-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px 14px;
    }
    .state-item strong {
      display: block;
      font-size: 0.88rem;
      margin-bottom: 3px;
      color: var(--text);
    }
    .state-item span {
      color: var(--muted);
      font-size: 0.79rem;
      line-height: 1.45;
    }
    .journal-box {
      background: #1f1b18;
      color: #f6efe6;
      border-radius: 18px;
      margin: 0 20px 20px;
      padding: 16px;
      min-height: 260px;
      font-family: Consolas, monospace;
      font-size: 0.8rem;
      line-height: 1.65;
      overflow: auto;
    }
    .journal-line {
      margin-bottom: 8px;
      color: #e9dccb;
    }
    .journal-line .ts { color: #8cc9c3; }
    .journal-line.ok { color: #a7efc0; }
    .journal-line.warn { color: #f2c078; }
    .journal-line.err { color: #f3a0a0; }

    /* ── RESULT STATE HEADER ── */
    #resultState { display: inline-block; }

    /* ── TABLE ── */
    .table-wrap { overflow-x: auto; padding: 0 18px 16px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    th {
      text-align: left; padding: 8px 12px;
      font-size: 0.7rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.7px;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }
    td { padding: 9px 12px; border-bottom: 1px solid rgba(0,0,0,0.05); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(15,118,110,0.03); }

    /* ── BATCH PROGRESS ── */
    .batch-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 18px;
    }
    .batch-card h3 { font-size: 0.85rem; font-weight: 600; margin-bottom: 12px; }
    .batch-day {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 7px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      font-size: 0.8rem;
    }
    .batch-day:last-child { border-bottom: none; }
    .batch-day .d-label { width: 90px; color: var(--muted); }
    .batch-day .d-bar { flex: 1; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
    .batch-day .d-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
    .batch-day .d-status { width: 80px; text-align: right; font-size: 0.72rem; }
    .d-fill.pending  { background: var(--border); width: 0%; }
    .d-fill.running  { background: var(--accent); width: 50%; animation: pulse-bar 1s infinite; }
    .d-fill.done     { background: var(--green); width: 100%; }
    .d-fill.error    { background: var(--red); width: 100%; }
    @keyframes pulse-bar { 0%,100%{opacity:1} 50%{opacity:0.5} }

    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; gap: 12px; padding: 12px; }
      .sidebar { order: 2; }
      .main-col { order: 1; gap: 12px; }
      #summary { grid-template-columns: repeat(2,1fr); gap: 8px; }
      .main-grid { grid-template-columns: 1fr; gap: 12px; }
      body { padding-bottom: 78px; }
      header { padding: 14px 16px; }
      .top-tabs { width: 100%; }
      .top-tab { flex: 1 1 0; justify-content: center; }
      .hero-card { padding: 18px 16px; }
      .hero-card h2 { font-size: 1.35rem; }
      .section-head, .full-day-group-head { align-items: flex-start; flex-direction: column; }
      .table-wrap { padding-inline: 12px; }
      .full-day-group { margin: 12px 12px 16px; }
      .chip-row { padding-inline: 12px; }
      .urgent-grid { padding-inline: 12px; }
      .result-head { align-items: flex-start; flex-direction: column; gap: 8px; }
      .version-badge { width: 100%; justify-content: center; }
      .mobile-dock {
        display: flex;
        position: sticky;
        bottom: 0;
        z-index: 30;
        gap: 8px;
        padding: 10px 12px 12px;
        background: linear-gradient(180deg, rgba(244,241,234,0), rgba(244,241,234,0.96) 18%, rgba(244,241,234,0.98));
      }
      .mobile-dock .dock-btn {
        flex: 1 1 0;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: #fff;
        color: var(--text);
        font-size: 0.76rem;
        font-weight: 700;
        padding: 10px 8px;
        box-shadow: var(--shadow);
      }
      .mobile-dock .dock-btn.primary {
        background: linear-gradient(135deg, #0f766e, #c77d18);
        color: #fff;
        border-color: transparent;
      }
      .mobile-dock .dock-btn.secondary {
        background: rgba(15,118,110,0.08);
        color: var(--accent);
      }
      .mobile-stack {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 12px 12px 16px;
      }
      .mobile-course-card {
        border: 1px solid var(--border);
        border-radius: 16px;
        background: #fff;
        padding: 12px;
        box-shadow: var(--shadow);
      }
      .mobile-course-top {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        align-items: flex-start;
        margin-bottom: 8px;
      }
      .mobile-course-title { font-size: 0.92rem; font-weight: 800; color: var(--text); line-height: 1.25; }
      .mobile-course-sub { font-size: 0.78rem; color: var(--muted); margin-top: 4px; line-height: 1.4; }
      .mobile-course-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        margin-top: 10px;
      }
      .mobile-course-box {
        background: rgba(255,255,255,0.72);
        border: 1px solid rgba(216,207,191,.8);
        border-radius: 12px;
        padding: 8px 10px;
      }
      .mobile-course-box .k {
        display: block;
        font-size: 0.68rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
      }
      .mobile-course-box .v {
        font-size: 0.82rem;
        color: var(--text);
        font-weight: 700;
      }
      .mobile-course-actions {
        display: flex;
        gap: 8px;
        margin-top: 10px;
