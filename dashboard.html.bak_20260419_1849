  function buildRaceDateTime(iso, hhmm) {
    if (!iso || !hhmm || !hhmm.includes(":")) return null;
    return new Date(`${iso}T${hhmm}:00`);
  }

  function normalizeCourseKey(reunion, course) {
    return `${String(reunion || "").replace(/\s+/g, "")}-${String(course || "").replace(/\s+/g, "")}`;
  }

  function parseCourseFilter(raw) {
    const value = String(raw || "").trim().toUpperCase().replace(/\s+/g, "");
    if (!value) return null;
    const match = value.match(/^R?(\d+)C(\d+)$/);
    if (match) {
      return { reunion: match[1], course: match[2], key: `R${match[1]}C${match[2]}` };
    }
    return null;
  }

  function decorateAnalysisItem(item, iso) {
    const raceAt = buildRaceDateTime(iso, item.heure_depart);
    const now = new Date();
    let minutesToDepart = null;
    let secondsToDepart = null;
    const isTodayView = iso === isoToday();
    const isPastView = compareIsoDate(iso, isoToday()) < 0;
    const liveTicket = getLiveTicketSnapshot(item.reunion, item.course);
    const watcherLive = isTodayView ? getWatcherLiveCote(item.reunion, item.course) : null;
    const settledSet = getSettledCourseKeySet();
    const hasSettledData = Boolean(currentPnlJson && Array.isArray(currentPnlJson.details) && currentPnlJson.details.length > 0);
    const settledPlayed = hasSettledData
      ? settledSet.has(normalizeCourseKey(item.reunion, item.course))
      : false;
    const raceStillUpcoming = Boolean(raceAt && raceAt.getTime() > now.getTime());
    const isUpcoming = isPastView ? false : (!settledPlayed && raceStillUpcoming);
    if (raceAt && isTodayView && !settledPlayed) {
      secondsToDepart = Math.floor((raceAt.getTime() - now.getTime()) / 1000);
      minutesToDepart = secondsToDepart >= 0 ? Math.ceil(secondsToDepart / 60) : -1;
    }
    return {
      ...item,
      played: settledPlayed,
      isUpcoming,
      isPastView,
      hasSelection: item.selection !== null,
      minutesToDepart,
      secondsToDepart,
      liveTicket: {
        ...(liveTicket || {}),
        cote_live: Number.isFinite(Number(watcherLive))
          ? Number(watcherLive)
          : (Number.isFinite(Number(liveTicket?.cote_live)) ? Number(liveTicket.cote_live) : null),
      },
    };
  }

  function getLiveTicketSnapshot(reunion, course) {
    if (!currentTicketProchainJson || !Array.isArray(currentTicketProchainJson.toutes_courses)) return null;
    return currentTicketProchainJson.toutes_courses.find(row =>
      String(row.reunion) === String(reunion) && String(row.course) === String(course)
    ) || null;
  }

  function getWatcherLiveCote(reunion, course) {
    const state = watcherHealthJson || {};
    const byCourse = state.live_cotes_by_course || {};
    const keys = [
      `${String(state.last_course_id || "")}`,
      `${String(reunion)}_${String(course)}`,
      `${String(reunion)}C${String(course)}`,
      `${String(reunion)}_${String(course).replace(/^C/i, "")}`,
    ];
    for (const key of keys) {
      const value = byCourse?.[key];
      if (Number.isFinite(Number(value))) {
        return Number(value);
      }
    }
    if (Number.isFinite(Number(state.last_live_cote)) && String(state.last_course_id || "").includes(`_${String(reunion)}_C${String(course).replace(/^C/i, "")}`)) {
      return Number(state.last_live_cote);
    }
    return null;
  }

