      .mobile-course-grid { grid-template-columns: 1fr; }
      .mobile-dock { gap: 6px; padding-inline: 8px; }
      .mobile-dock .dock-btn { font-size: 0.7rem; padding: 10px 6px; }
    }
  </style>
</head>
<body>

<header>
  <div class="header-row">
    <div>
      <h1>PMU Moulinette</h1>
      <p>Flux du jour, analyse, départs imminents et lecture complète des courses sélectionnées.</p>
    </div>
    <nav class="top-tabs" aria-label="Navigation rapide">
      <button class="top-tab active" type="button" id="btnAnalysisTab">Analyse du jour</button>
      <button class="top-tab" type="button" id="btnFullDayCourses">Toutes les courses du jour</button>
    </nav>
  </div>
</header>

<div class="layout">

  <!-- ── SIDEBAR ── -->
  <div class="sidebar">

    <!-- Date picker -->
    <div class="card">
      <div class="card-title">Date</div>
      <div class="card-body">
        <div class="date-nav">
          <button id="btnPrev" title="Jour précédent">◀</button>
          <span id="selected-date-label">—</span>
          <button id="btnNext" title="Jour suivant">▶</button>
        </div>
        <input type="date" id="datepicker">
        <div class="quick-btns">
          <button class="quick-btn" data-offset="0">Aujourd'hui</button>
          <button class="quick-btn" data-offset="-1">Hier</button>
          <button class="quick-btn" data-offset="-2">Avant-hier</button>
          <button class="quick-btn" data-offset="-7">Il y a 7j</button>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="card">
      <div class="card-title">Actions</div>
      <div class="card-body">
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px">
          <input type="text" id="courseFilter" placeholder="R1C1" style="flex:1">
          <button class="action-btn btn-analyse" id="btnSingleCourse" onclick="runSingleCourse()">Analyser la course</button>
        </div>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px">
          <label for="dayBankroll" style="min-width:110px;color:var(--muted);font-size:0.88rem">Bankroll du jour</label>
          <input type="number" id="dayBankroll" min="1" step="1" value="100" style="flex:1">
        </div>
        <button class="action-btn btn-all" id="btnAlerts" type="button" onclick="enableTicketAlerts()">Activer alertes téléphone</button>
        <button class="action-btn btn-all"     id="btnAll"     onclick="runAll()">Flux complet</button>
        <button class="action-btn btn-import"  id="btnImport"  onclick="runPipeline()">Préparer les données</button>
        <button class="action-btn btn-analyse" id="btnAnalyse" onclick="runAnalysis()">Lancer l’analyse</button>
        <button class="action-btn btn-gains"   id="btnGains"   onclick="runPnl()">Calculer les gains</button>
      </div>
    </div>

    <!-- Multi-dates -->
    <div class="card">
      <div class="card-title">Plage</div>
      <div class="card-body">
        <label class="multi-toggle">
          <input type="checkbox" id="multiToggle"> Activer le mode plage
        </label>
        <div class="multi-section" id="multiSection">
          <div class="multi-row">
            <label>Du</label>
            <input type="date" id="dateFrom">
          </div>
          <div class="multi-row">
            <label>Au</label>
            <input type="date" id="dateTo">
          </div>
          <div class="multi-info" id="multiInfo">Sélectionnez une plage pour voir le nombre de jours.</div>
          <button class="action-btn btn-all" id="btnBatch" onclick="runBatch()">Lancer la plage</button>
        </div>
      </div>
    </div>

    <!-- Status -->
    <div class="card">
      <div class="card-title">Statut</div>
      <div class="card-body" style="padding:12px 14px">
        <div class="progress-wrap" id="progressWrap">
          <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
          <div class="progress-label" id="progressLabel"></div>
        </div>
        <div id="statusBox">Prêt.</div>
      </div>
    </div>

  </div>

  <!-- ── MAIN ── -->
  <div class="main-col">
    <section class="hero-card">
      <div class="hero-kicker">Prévisualisation Validée</div>
      <h2>Départs dans 5 min, puis toutes les sélections du jour.</h2>
      <p>La page met en avant les courses imminentes, puis déroule la liste complète des courses sélectionnées avec un état système simple et un journal technique lisible.</p>
      <button class="version-badge" id="versionBadge" type="button" data-toggle-full-day="true">Vue complète triée par réunion et filtrable</button>
    </section>
    <div id="summary" style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0" id="resultHeader" style="display:none">
      <span id="resultState" class="pill warn">Aucune action</span>
    </div>
    <div class="main-grid">
      <div class="primary-col">
        <div id="results"></div>
        <div id="batchResults"></div>
      </div>
      <aside class="side-col">
        <section class="section-card">
          <div class="section-head">
            <div>
              <h2>État système</h2>
              <p>Lecture rapide de la journée en cours.</p>
            </div>
          </div>
          <div class="state-stack" id="stateSystem"></div>
        </section>
        <section class="section-card">
          <div class="section-head">
            <div>
              <h2>Journal</h2>
              <p>Étapes utiles et derniers retours du pipeline.</p>
            </div>
          </div>
          <div class="journal-box" id="journalBox"></div>
