    if (!("Notification" in window)) {
      setStatus("Les notifications navigateur ne sont pas supportées sur cet appareil.", true);
      return;
    }
    const permission = await Notification.requestPermission();
    if (permission === "granted") {
      ticketAlertsEnabled = true;
      localStorage.setItem(TICKET_ALERTS_STORAGE_KEY, "1");
      if ($("btnAlerts")) $("btnAlerts").textContent = "Alertes tickets actives";
      setStatus("Alertes téléphone activées.");
      pushJournal("Notifications navigateur activées pour les tickets à jouer sur téléphone.", "ok");
    } else {
      setStatus("Notifications refusées ou non autorisées.", true);
    }
  }

