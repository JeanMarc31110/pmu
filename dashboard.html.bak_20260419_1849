</div>

<div class="mobile-dock" aria-label="Actions rapides mobiles">
  <button class="dock-btn secondary" type="button" onclick="runPipeline()">Préparer</button>
  <button class="dock-btn primary" type="button" onclick="runAnalysis()">Analyser</button>
  <button class="dock-btn secondary" type="button" onclick="runPnl()">Gains</button>
  <button class="dock-btn secondary" type="button" data-toggle-full-day="true">Courses</button>
</div>

<script>
  const $ = id => document.getElementById(id);
  const BASE_URL = window.location.origin + "/pmu";
  const PHONE_PUSH_TOPIC = "pmu-resultats-22h-rigai";

  function formatWatcherAge(seconds) {
    if (!Number.isFinite(seconds) || seconds < 0) return "inconnue";
    if (seconds < 60) return `${Math.max(1, Math.round(seconds))} s`;
    const minutes = Math.floor(seconds / 60);
    const remaining = Math.round(seconds % 60);
    if (minutes < 60) {
      return remaining ? `${minutes} min ${remaining}s` : `${minutes} min`;
    }
    const hours = Math.floor(minutes / 60);
    const mins = minutes % 60;
    return mins ? `${hours} h ${mins} min` : `${hours} h`;
  }

  function phonePushState() {
    const state = watcherHealthJson || {};
    const status = String(state.watcher_status || "unknown").toLowerCase();
    const ageSeconds = Number(state.age_seconds);
    const stale = state.is_stale === true || (Number.isFinite(ageSeconds) && ageSeconds > 180);
    const lastTicket = String(state.last_ticket || "").trim();
    const lastChecked = state.last_checked_at ? formatWatcherAge(ageSeconds) : "inconnue";
    const baseText = `Topic ntfy : ${PHONE_PUSH_TOPIC}.`;

    if (status === "error") {
      return {
        title: "Watcher D-5",
        text: `${baseText} Dernière erreur: ${String(state.last_error || "inconnue")}.`,
        badge: "no",
        label: "Erreur",
      };
    }

    if (stale) {
      return {
        title: "Watcher D-5",
        text: `${baseText} Aucune activité récente. Dernière activité: ${lastChecked}. ${lastTicket ? `Dernier ticket: ${lastTicket}.` : ""}`.trim(),
        badge: "warn",
        label: "Silencieux",
      };
    }

    return {
      title: "Watcher D-5",
      text: `${baseText} Dernière activité il y a ${lastChecked}. ${lastTicket ? `Dernier ticket: ${lastTicket}.` : "Aucun ticket récent."}`.trim(),
      badge: "ok",
      label: "Actif",
    };
  }

  async function refreshWatcherHealth() {
    try {
      const json = await callScript("watcher_status.php");
      watcherHealthJson = json;
      renderSystemState();
      return json;
    } catch (err) {
      watcherHealthJson = {
        watcher_status: "error",
        last_error: err.message || String(err),
      };
      renderSystemState();
      return null;
    }
  }

  // ── FORMAT ──────────────────────────────────────────────────────────
  function toJJMMAAAA(dateStr) {
    // dateStr = "YYYY-MM-DD"
    const [y, m, d] = dateStr.split("-");
    return d + m + y;
  }
  function fromJJMMAAAA(s) {
    // s = "DDMMYYYY"
    return s.slice(4) + "-" + s.slice(2, 4) + "-" + s.slice(0, 2);
  }
  function labelDate(dateStr) {
    const d = new Date(dateStr + "T00:00:00");
    return d.toLocaleDateString("fr-FR", { weekday:"long", day:"2-digit", month:"long", year:"numeric" });
  }
  function isoToday() {
    const now = new Date();
    const y = now.getFullYear();
    const m = String(now.getMonth() + 1).padStart(2, "0");
    const d = String(now.getDate()).padStart(2, "0");
    return `${y}-${m}-${d}`;
  }
  function compareIsoDate(a, b) {
    if (!a || !b) return 0;
    if (a === b) return 0;
    return a < b ? -1 : 1;
  }
  function addDays(iso, n) {
    const d = new Date(iso + "T00:00:00");
    d.setDate(d.getDate() + n);
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, "0");
    const day = String(d.getDate()).padStart(2, "0");
    return `${y}-${m}-${day}`;
  }
  function daysBetween(from, to) {
    return Math.round((new Date(to) - new Date(from)) / 86400000) + 1;
  }

  let currentAnalysisJson = null;
  let currentPnlJson = null;
  let currentFullDayJson = null;
  let currentTicketProchainJson = null;
  let currentCourseFilter = "all";
  let fullDayCoursesFilter = "all";
  let fullSelectionListOpen = false;
  let fullDayCoursesOpen = false;
  let journalEntries = [];
  let currentCourseKey = "";
  const DAY_BANKROLL_STORAGE_KEY = "pmu.dayBankroll";
  const TICKET_ALERTS_STORAGE_KEY = "pmu.ticketAlertsEnabled";
  let ticketAlertsEnabled = localStorage.getItem(TICKET_ALERTS_STORAGE_KEY) === "1";
  let lastTicketAlertSignature = "";
  let watcherHealthJson = null;
  let localTimeRefreshHandle = null;
  let autoCourseAnalysisState = {};
  let autoCourseAnalysisRunning = false;
  let analysisRunSeq = 0;
  let pnlRunSeq = 0;

  // ── DATE STATE ────────────────────────────────────────────────────────
  let currentIso = isoToday();

  function setDate(iso) {
    currentIso = iso;
    clearLocalTimeRefresh();
    resetAutoCourseAnalysisState();
    resetControls();
    $("datepicker").value = iso;
    $("selected-date-label").textContent = labelDate(iso);
    if (fullDayCoursesOpen) {
      fullDayCoursesOpen = false;
      currentFullDayJson = null;
      fullDayCoursesFilter = "all";
      setTopTabState();
    }
    // Update quick btn active state
    const today = isoToday();
    document.querySelectorAll(".quick-btn").forEach(btn => {
      const offset = parseInt(btn.dataset.offset);
      btn.classList.toggle("active", addDays(today, offset) === iso);
    });
  }

  // Init
  setDate(isoToday());
  const savedDayBankroll = localStorage.getItem(DAY_BANKROLL_STORAGE_KEY);
  if (savedDayBankroll !== null && $("dayBankroll")) {
    $("dayBankroll").value = savedDayBankroll;
  }
  if ($("btnAlerts")) {
    $("btnAlerts").textContent = (ticketAlertsEnabled && isMobileAlertContext() && "Notification" in window && Notification.permission === "granted")
      ? "Alertes téléphone actives"
      : "Activer alertes téléphone";
  }

  // Date picker events
  $("datepicker").addEventListener("change", e => setDate(e.target.value));
  $("btnPrev").addEventListener("click", () => setDate(addDays(currentIso, -1)));
  $("btnNext").addEventListener("click", () => setDate(addDays(currentIso, +1)));
  $("btnAnalysisTab").addEventListener("click", () => {
    fullDayCoursesOpen = false;
    currentFullDayJson = null;
    setTopTabState();
    if (currentAnalysisJson) {
      renderAnalysisDashboard();
    } else {
      renderDashboardPlaceholder();
    }
    setStatus("Vue analyse active.");
  });
  $("btnFullDayCourses").addEventListener("click", () => {
    toggleFullDayCourses().catch(err => alert(err.message));
  });
  $("dayBankroll").addEventListener("change", e => {
    const value = normalizeBankrollValue(e.target.value);
    e.target.value = value;
    localStorage.setItem(DAY_BANKROLL_STORAGE_KEY, String(value));
    setStatus(`Bankroll du jour réglée à ${value} €.`);
  });

  document.querySelectorAll(".quick-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      setDate(addDays(isoToday(), parseInt(btn.dataset.offset)));
    });
  });

  // Multi-date toggle
  $("multiToggle").addEventListener("change", e => {
    $("multiSection").classList.toggle("visible", e.target.checked);
  });

  function updateMultiInfo() {
    const from = $("dateFrom").value;
    const to   = $("dateTo").value;
    if (from && to && to >= from) {
      const n = daysBetween(from, to);
      $("multiInfo").textContent = `${n} jour(s) sélectionné(s) — Pipeline complet sur chaque jour.`;
    } else {
      $("multiInfo").textContent = "Sélectionnez une plage valide.";
    }
  }
  $("dateFrom").addEventListener("change", updateMultiInfo);
  $("dateTo").addEventListener("change", updateMultiInfo);

  // ── HELPERS ───────────────────────────────────────────────────────────
  function setStatus(msg, isError = false) {
    $("statusBox").textContent = msg;
    $("statusBox").style.color = isError ? "#f56565" : "#5a6488";
    pushJournal(msg, isError ? "err" : "info");
  }

  function resetControls() {
    ["datepicker","btnPrev","btnNext","btnAnalysisTab","btnFullDayCourses",
     "btnAll","btnImport","btnAnalyse","btnGains","btnBatch","btnSingleCourse","dayBankroll"].forEach(id => {
      const el = $(id);
      if (el) el.disabled = false;
    });
  }

  function normalizeBankrollValue(value) {
    const n = Number.parseFloat(value);
    if (!Number.isFinite(n) || n <= 0) return 100;
    return Math.round(n);
  }

  function getDayBankroll() {
    const input = $("dayBankroll");
    const value = normalizeBankrollValue(input ? input.value : 100);
    if (input) input.value = value;
    localStorage.setItem(DAY_BANKROLL_STORAGE_KEY, String(value));
    return value;
  }

  function setResultState(text, mode = "warn") {
    const el = $("resultState");
    el.textContent = text;
    el.className = "pill " + mode;
  }

  function timeStamp() {
    return new Date().toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit", second: "2-digit" });
  }

  function pushJournal(message, level = "info") {
    if (!message) return;
    journalEntries.unshift({ ts: timeStamp(), message, level });
    journalEntries = journalEntries.slice(0, 18);
    renderJournal();
  }

  function clearLocalTimeRefresh() {
    if (localTimeRefreshHandle) {
      clearInterval(localTimeRefreshHandle);
      localTimeRefreshHandle = null;
    }
  }

  function resetAutoCourseAnalysisState() {
    autoCourseAnalysisState = {};
    autoCourseAnalysisRunning = false;
  }

  function getCourseKey(item) {
    if (!item) return "";
    return normalizeCourseKey(item.reunion, item.course);
  }

  function formatCourseCode(item) {
    const reunion = String(item?.reunion || "").replace(/^R/i, "");
    const course = String(item?.course || "").replace(/^C/i, "");
    if (!reunion || !course) return "—";
    return `R${reunion}C${course}`;
  }

  function readAutoCourseState(item) {
    return autoCourseAnalysisState[getCourseKey(item)] || null;
  }

  function isCourseFrozen(item) {
    const state = readAutoCourseState(item);
    return Boolean(state && state.pushStatus === "sent");
  }

  function writeAutoCourseState(item, patch = {}) {
    const key = getCourseKey(item);
    if (!key) return;
    autoCourseAnalysisState[key] = {
      ...(autoCourseAnalysisState[key] || {}),
      ...patch,
      updatedAt: new Date().toISOString(),
    };
  }

  function findCurrentCourseItem(reunion, course) {
    if (!currentAnalysisJson || !Array.isArray(currentAnalysisJson.data)) return null;
    return currentAnalysisJson.data.find(item =>
      String(item.reunion) === String(reunion) && String(item.course) === String(course)
    ) || null;
  }

  async function maybeAutoPushAfterAnalysis(item) {
    const key = getCourseKey(item);
    if (!key) return;
    const state = autoCourseAnalysisState[key] || {};
    if (state.pushStatus === "sent" || state.pushStatus === "running") return;

    const dateIso = currentAnalysisJson?.date ? fromJJMMAAAA(currentAnalysisJson.date) : currentIso;
    const fresh = findCurrentCourseItem(item.reunion, item.course);
    const decorated = fresh ? decorateAnalysisItem(fresh, dateIso) : null;
    if (!decorated || !decorated.selection || decorated.played || !canAnalyzeCourseNow(decorated)) {
      writeAutoCourseState(item, {
        pushStatus: "skipped",
        pushMessage: "Non jouable après analyse",
      });
      return;
    }

    writeAutoCourseState(item, {
      pushStatus: "running",
      pushMessage: "Préparation push...",
    });
    renderAnalysisDashboard();
    try {
      await preparePmuTicket(decorated);
      writeAutoCourseState(item, {
        pushStatus: "sent",
        pushMessage: "Push envoyé",
      });
    } catch (err) {
      writeAutoCourseState(item, {
        pushStatus: "error",
        pushMessage: String(err?.message || "Erreur push"),
      });
    }
  }

  function applySingleCourseAnalysisResult(row) {
    if (!currentAnalysisJson || !Array.isArray(currentAnalysisJson.data) || !row) return;
    const idx = currentAnalysisJson.data.findIndex(item =>
      String(item.reunion) === String(row.reunion) && String(item.course) === String(row.course)
    );
    if (idx === -1) return;
    currentAnalysisJson.data[idx] = row;
  }

  async function runAutoCourseAnalysis(item) {
    const date = currentAnalysisJson?.date;
    if (!date) return;
    const params = {
      date: String(date),
      capital: getDayBankroll(),
      reunion: String(item.reunion),
      course: String(item.course),
    };
    writeAutoCourseState(item, { status: "running", message: "Analyse en cours..." });
    renderAnalysisDashboard();
    try {
      const json = await callScript("query_day_moulinette_summary.php", params);
      const row = Array.isArray(json.data) ? json.data[0] : null;
      if (row) {
        applySingleCourseAnalysisResult(row);
      }
      writeAutoCourseState(item, {
        status: "ok",
        message: "Analyse D-5 validée",
      });
      pushJournal(`Auto-analyse D-5 validée sur R${item.reunion}C${item.course}.`, "ok");
      await maybeAutoPushAfterAnalysis(item);
    } catch (err) {
      writeAutoCourseState(item, {
        status: "error",
        message: String(err?.message || "Erreur auto-analyse"),
      });
      pushJournal(`Auto-analyse D-5 en erreur sur R${item.reunion}C${item.course}: ${String(err?.message || err)}`, "err");
    }
  }

  async function maybeAutoAnalyzeDueCourses() {
    if (autoCourseAnalysisRunning) return;
    if (!currentAnalysisJson || !Array.isArray(currentAnalysisJson.data)) return;
    const dateIso = fromJJMMAAAA(currentAnalysisJson.date);
    if (dateIso !== isoToday()) return;

    const decorated = currentAnalysisJson.data.map(item => decorateAnalysisItem(item, dateIso));
    const due = decorated.filter(item => {
      if (!item || !item.hasSelection || item.played) return false;
      if (!canAnalyzeReunionNow(item, decorated, dateIso)) return false;
      const state = readAutoCourseState(item);
      return !state || (state.status !== "ok" && state.status !== "running");
    });
    if (!due.length) return;

    autoCourseAnalysisRunning = true;
    try {
      for (const item of due) {
        await runAutoCourseAnalysis(item);
      }
      const pendingPush = decorated.filter(item => {
        if (!item || !item.hasSelection || item.played) return false;
        if (!canAnalyzeCourseNow(item)) return false;
        const state = readAutoCourseState(item);
        return state && state.status === "ok" && state.pushStatus !== "sent" && state.pushStatus !== "running";
      });
      for (const item of pendingPush) {
        await maybeAutoPushAfterAnalysis(item);
      }
    } finally {
      autoCourseAnalysisRunning = false;
      renderAnalysisDashboard();
    }
  }

  function renderAutoCourseAnalysisPanel(selected = [], dateIso = null) {
    const isTodayView = dateIso === isoToday();
    const rows = selected.slice(0, 12).map(item => {
      const state = readAutoCourseState(item);
      let label = "En attente D-5 réunion";
      let cls = "warn";
      if (item.played) {
        label = "Course partie";
        cls = "";
      } else if (state?.pushStatus === "sent") {
        label = "Figée (push envoyé)";
        cls = "ok";
      } else if (state?.status === "running") {
        label = "Analyse en cours";
        cls = "warn";
      } else if (state?.status === "ok") {
        label = "Analysée";
        cls = "ok";
      } else if (state?.status === "error") {
        label = "Erreur";
        cls = "no";
      } else if (canAnalyzeCourseNow(item)) {
        label = "À analyser";
        cls = "warn";
      }
      return `
        <tr>
          <td>${item.heure_depart || "—"}</td>
          <td>${formatCourseCode(item)}</td>
          <td>${item.selection ? `${item.selection.num} - ${item.selection.nom}` : "—"}</td>
          <td><span class="pill ${cls}">${label}</span></td>
          <td>${state?.message || "—"}${state?.pushMessage ? ` · ${state.pushMessage}` : ""}</td>
        </tr>
      `;
    }).join("");

