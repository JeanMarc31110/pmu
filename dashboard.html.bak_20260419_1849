  function getReunionFirstDeparture(dateIso, reunion, items = []) {
    if (!dateIso || !reunion || !Array.isArray(items)) return null;
    const times = items
      .filter(row => row && String(row.reunion) === String(reunion))
      .map(row => buildRaceDateTime(dateIso, row.heure_depart))
      .filter(Boolean)
      .sort((a, b) => a.getTime() - b.getTime());
    return times.length ? times[0] : null;
  }

  function canAnalyzeReunionNow(item, allItems = null, dateIso = null) {
    if (!item) return false;
    if (isCourseFrozen(item)) return false;
    const iso = dateIso || (currentAnalysisJson?.date ? fromJJMMAAAA(currentAnalysisJson.date) : currentIso);
    if (iso !== isoToday()) return false;
    const source = Array.isArray(allItems)
      ? allItems
      : (currentAnalysisJson && Array.isArray(currentAnalysisJson.data) ? currentAnalysisJson.data : []);
    const firstDeparture = getReunionFirstDeparture(iso, item.reunion, source);
    if (!firstDeparture) return false;
    const gateAt = new Date(firstDeparture.getTime() - 5 * 60 * 1000);
    return new Date().getTime() >= gateAt.getTime();
  }

  function getFullDayRows() {
    if (!currentFullDayJson || !Array.isArray(currentFullDayJson.data)) return [];
    const iso = currentFullDayJson.date ? fromJJMMAAAA(currentFullDayJson.date) : currentIso;
    const now = new Date();
    const isPastView = compareIsoDate(iso, isoToday()) < 0;
    const settledSet = getSettledCourseKeySet();
    const hasSettledData = Boolean(currentPnlJson && Array.isArray(currentPnlJson.details) && currentPnlJson.details.length > 0);
    return currentFullDayJson.data.map(entry => {
      const course = entry.course || {};
      const played = hasSettledData
        ? settledSet.has(normalizeCourseKey(course.reunion, course.course))
        : false;
      const raceAt = buildRaceDateTime(iso, course.heure_depart);
      const raceStillUpcoming = Boolean(raceAt && raceAt.getTime() > now.getTime());
      const isUpcoming = isPastView ? false : (!played && raceStillUpcoming);
      const upcomingSoon = Boolean(
        raceAt &&
        iso === isoToday() &&
        isUpcoming &&
        raceAt.getTime() - now.getTime() <= 5 * 60 * 1000
      );
      return {
        ...entry,
        course,
        played,
        isUpcoming,
        isPastView,
        upcomingSoon,
      };
    });
  }

  function filterFullDayRows(rows) {
