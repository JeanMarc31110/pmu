  function groupFullDayRows(rows) {
    const groups = new Map();
    rows.forEach(item => {
      const reunion = item.course && item.course.reunion !== undefined && item.course.reunion !== null
        ? String(item.course.reunion)
        : "—";
      if (!groups.has(reunion)) groups.set(reunion, []);
      groups.get(reunion).push(item);
    });
    return Array.from(groups.entries())
      .map(([reunion, items]) => ({
        reunion,
        items: items.slice().sort((a, b) => {
          if (a.upcomingSoon !== b.upcomingSoon) return a.upcomingSoon ? -1 : 1;
          const ha = (a.course && a.course.heure_depart) || "";
          const hb = (b.course && b.course.heure_depart) || "";
          if (ha !== hb) return ha.localeCompare(hb);
          return Number(a.course && a.course.course ? a.course.course : 0) - Number(b.course && b.course.course ? b.course.course : 0);
