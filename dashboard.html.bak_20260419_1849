  // ── PIPELINE ──────────────────────────────────────────────────────────
  async function runPipeline(dateIso = null) {
    const iso  = dateIso || currentIso;
    const date = toJJMMAAAA(iso);
    closeFullDayCoursesView();
    if (!dateIso) {
      renderDashboardPlaceholder();
    }
    resetControls();
    lockBtns(true); $("results").innerHTML = ""; $("summary").style.display = "none";
    setResultState("Pipeline en cours", "warn");
    const steps = [
      ["1/5 Import des courses...",              () => callScript("fetch_to_sqlite.php",                  { date })],
      ["2/5 Réparation drivers/jockeys...",      () => callScript("repair_driver_jockey.php",             { date, date_filter: date })],
      ["3/5 Construction JT...",                 () => callScript("build_jt_reference_from_base.php",     { min_courses: 1 })],
      ["4/5 Injection des cotes du jour...",     () => callScript("inject_market_odds_day_from_raw.php",  { date })],
      ["5/5 Rebuild des inputs moulinette...",   () => callScript("build_moulinette_inputs.php",          { date })],
    ];
    try {
      const results = [];
      for (let i = 0; i < steps.length; i++) {
        const [label, fn] = steps[i];
        setStatus(label);
        setProgress(Math.round((i / steps.length) * 100), `Étape ${i+1}/${steps.length}`);
        results.push(await fn());
      }
      const [a, b, c, d, e] = results;
      pushJournal("Pipeline complet terminé.", "ok");
      setProgress(100, "Terminé");
      $("summary").style.display = "grid";
      $("summary").innerHTML = `
        <div class="box"><div class="k">Date importée</div><div class="v">${date}</div></div>
        <div class="box"><div class="k">Courses</div><div class="v">${a.total_courses_processed ?? 0}</div></div>
        <div class="box"><div class="k">Participants</div><div class="v">${a.total_participants_inserted ?? 0}</div></div>
        <div class="box"><div class="k">Qualifiés finaux</div><div class="v">${e.stats?.qualifies_final ?? 0}</div></div>`;
      renderImportResult([
        `Drivers réparés : ${b.updated ?? 0}`,
        `Couples JT construits : ${c.jt_pairs_built ?? 0}`,
        `Cotes injectées : ${d.inserted ?? 0}`,
        `Courses touchées : ${d.courses_touched ?? 0}`,
        `Inputs upserted : ${e.rows_upserted ?? 0}`,
        `Qualifiés Q5 : ${e.stats?.qualifies_q5 ?? 0}`,
        `Qualifiés finaux : ${e.stats?.qualifies_final ?? 0}`
      ]);
      await refreshWatcherHealth();
      setResultState("Pipeline terminé", "ok");
      setStatus("Import et préparation terminés avec succès.");
      return true;
    } catch(err) {
      pushJournal(`Erreur pipeline : ${err.message}`, "err");
      setResultState("Erreur pipeline", "no");
      setStatus(err.message, true);
      $("results").innerHTML = `<div class="result-card"><div class="result-head"><div class="title">Erreur pipeline</div><div class="pill no">Erreur</div></div><div class="status">${err.message}</div></div>`;
      return false;
    } finally {
      if (!dateIso) lockBtns(false);
    }
  }

  async function runAnalysis(dateIso = null) {
    const runSeq = ++analysisRunSeq;
    const iso  = dateIso || currentIso;
    const isTodayAnalysis = iso === isoToday();
    const date = toJJMMAAAA(iso);
    const course = parseCourseFilter($("courseFilter")?.value || "");
    const capital = getDayBankroll();
    if (!dateIso) { lockBtns(true); $("results").innerHTML = ""; $("summary").style.display = "none"; }
    setResultState("Analyse en cours", "warn");
    try {
      setStatus("Analyse de la journée en cours...");
      resetAutoCourseAnalysisState();
      const params = { date, capital };
      if (course) {
        params.reunion = course.reunion;
        params.course = course.course;
      }
      const json = await callScript("query_day_moulinette_summary.php", params);
      const data = Array.isArray(json.data) ? json.data : [];
      const jouees = data.filter(x => x.selection !== null).length;
      const abstentions = data.length - jouees;
      currentAnalysisJson = json;
      currentPnlJson = null;
      currentCourseFilter = "all";
      currentCourseKey = course ? course.key : "";
      fullSelectionListOpen = false;
      $("summary").style.display = "grid";
      if (isTodayAnalysis) {
        await refreshLiveTicketSnapshot(iso, capital);
      } else {
        currentTicketProchainJson = null;
      }
      if (runSeq !== analysisRunSeq) return false;
      await refreshFullDayCourses(iso);
      if (runSeq !== analysisRunSeq) return false;
      if (isTodayAnalysis) {
        await refreshWatcherHealth();
      }
      if (runSeq !== analysisRunSeq) return false;
      const decoratedData = getDecoratedAnalysisData(json);
      currentAnalysisJson = { ...json, data: decoratedData };
      const selectedData = decoratedData.filter(item => item && item.hasSelection);
      renderAnalysisDashboard();
      ensureLocalTimeRefresh();
      maybeAutoAnalyzeDueCourses().catch(() => {});
      focusMainResults();
      pushJournal(`Analyse chargée : ${jouees} sélection(s), ${abstentions} abstention(s).`, "ok");
      setResultState("Analyse terminée", "ok");
      setStatus(`Analyse terminée : ${jouees} sélection(s), ${abstentions} abstention(s).`);
      renderSummaryCards({
        courses: json.courses_count ?? data.length,
        selected: selectedData.length,
        played: "—",
        upcoming: "—",
        abstentions: abstentions,
        totalStake: "Calcul en cours",
        net: "Calcul en cours",
        netColor: "var(--muted)",
      });
      try {
        const pnlParams = { date };
        pnlParams.capital = capital;
        if (course) {
          pnlParams.reunion = course.reunion;
          pnlParams.course = course.course;
        }
        const pnl = await callScript("query_day_moulinette_pnl.php", pnlParams);
        if (runSeq !== analysisRunSeq) return false;
        currentPnlJson = pnl;
        const selectedCount = selectedData.length;
        const playedCount = getSettledBetCount(pnl);
        const upcomingCount = selectedData.filter(item => item.isUpcoming).length;
        if (isTodayAnalysis) {
          await refreshLiveTicketSnapshot(iso, capital);
          if (runSeq !== analysisRunSeq) return false;
          await refreshWatcherHealth();
          if (runSeq !== analysisRunSeq) return false;
        }
        renderSummaryCards({
          courses: json.courses_count ?? data.length,
          selected: selectedCount,
          played: playedCount,
          upcoming: upcomingCount,
          abstentions: abstentions,
          totalStake: `${getSettledStakeTotal(pnl)} €`,
          net: `${pnl.resultat_net_total} €`,
          netColor: parseFloat(pnl.resultat_net_total) >= 0 ? "var(--green)" : "var(--red)",
        });
        await refreshFullDayCourses(iso);
        renderAnalysisDashboard();
        ensureLocalTimeRefresh();
        maybeAutoAnalyzeDueCourses().catch(() => {});
        focusMainResults();
        pushJournal(`Bilan auto chargé : ${pnl.resultat_net_total} € net sur ${pnl.nb_paris} pari(s).`, parseFloat(pnl.resultat_net_total) >= 0 ? "ok" : "warn");
      } catch (pnlErr) {
        pushJournal(`Bilan auto indisponible : ${pnlErr.message}`, "warn");
      }
      return true;
    } catch(err) {
      pushJournal(`Erreur analyse : ${err.message}`, "err");
      setResultState("Erreur analyse", "no");
      setStatus(err.message, true);
      $("results").innerHTML = `<div class="result-card"><div class="result-head"><div class="title">Erreur analyse</div><div class="pill no">Erreur</div></div><div class="status">${err.message}</div></div>`;
      return false;
    } finally {
      if (!dateIso) lockBtns(false);
    }
  }

  async function runPnl(dateIso = null) {
    const runSeq = ++pnlRunSeq;
    const iso  = dateIso || currentIso;
    const isTodayPnl = iso === isoToday();
    const date = toJJMMAAAA(iso);
    const course = parseCourseFilter($("courseFilter")?.value || "");
    const capital = getDayBankroll();
    if (!dateIso) { lockBtns(true); $("results").innerHTML = ""; $("summary").style.display = "none"; }
    setResultState("Calcul gains en cours", "warn");
    try {
      setStatus("Calcul des gains du jour...");
      const params = { date, capital };
      if (course) {
        params.reunion = course.reunion;
        params.course = course.course;
      }
      const json = await callScript("query_day_moulinette_pnl.php", params);
      if (runSeq !== pnlRunSeq) return null;
      currentPnlJson = json;
      const decoratedData = getDecoratedAnalysisData(currentAnalysisJson);
      const selectedCount = currentAnalysisJson ? decoratedData.filter(x => x.selection !== null).length : "—";
      const selectedData = currentAnalysisJson ? decoratedData.filter(item => item && item.hasSelection) : [];
      const playedCount = currentPnlJson ? getSettledBetCount(currentPnlJson) : "—";
      const upcomingCount = currentAnalysisJson ? selectedData.filter(item => item.isUpcoming).length : "—";
      if (isTodayPnl) {
        await refreshLiveTicketSnapshot(iso, capital);
        if (runSeq !== pnlRunSeq) return null;
        await refreshWatcherHealth();
        if (runSeq !== pnlRunSeq) return null;
      } else {
        currentTicketProchainJson = null;
      }
      renderSummaryCards({
        courses: currentAnalysisJson?.courses_count ?? "—",
        selected: selectedCount,
        played: playedCount,
        upcoming: upcomingCount,
        abstentions: currentAnalysisJson?.abstentions ?? "—",
        totalStake: `${getSettledStakeTotal(json)} €`,
        net: `${json.resultat_net_total} €`,
        netColor: parseFloat(json.resultat_net_total)>=0 ? "var(--green)" : "var(--red)",
      });
      if (currentAnalysisJson) {
        renderAnalysisDashboard();
        ensureLocalTimeRefresh();
        } else {
          clearLocalTimeRefresh();
          $("results").innerHTML = renderPnlTable(json.details || []);
        }
        focusMainResults();
      renderSystemState([
        { title: "Programme du jour", text: `${json.date} chargé et exploitable.`, badge: "ok", label: "OK" },
        { title: "Analyse moulinette", text: `${json.nb_paris || 0} pari(s) pris en compte · mise ${json.total_mise ?? 0} €.`, badge: "ok", label: "Calculée" },
        { title: "Bilan financier", text: `Résultat net ${json.resultat_net_total} € · bankroll fin ${json.bankroll_fin_theorique} €.`, badge: parseFloat(json.resultat_net_total) >= 0 ? "ok" : "no", label: "Terminé" },
        phonePushState(),
      ]);
      pushJournal(`Bilan du jour calculé : ${json.resultat_net_total} € net sur ${json.nb_paris} pari(s).`, parseFloat(json.resultat_net_total) >= 0 ? "ok" : "warn");
      setResultState("Gains calculés", "ok");
      setStatus(`Bilan terminé : ${json.nb_paris} pari(s), résultat net ${json.resultat_net_total} €.`);
      return json;
    } catch(err) {
      pushJournal(`Erreur gains : ${err.message}`, "err");
      setResultState("Erreur gains", "no");
      setStatus(err.message, true);
      $("results").innerHTML = `<div class="result-card"><div class="result-head"><div class="title">Erreur gains</div><div class="pill no">Erreur</div></div><div class="status">${err.message}</div></div>`;
      return null;
    } finally {
      if (!dateIso) lockBtns(false);
    }
  }

  async function runAll() {
    lockBtns(true);
    $("results").innerHTML = ""; $("summary").style.display = "none";
    setStatus("Lancement du pipeline complet...");
    const ok1 = await runPipeline(currentIso);
    if (!ok1) { lockBtns(false); return; }
    const ok2 = await runAnalysis(currentIso);
    if (!ok2) { lockBtns(false); return; }
    await runPnl(currentIso);
    lockBtns(false);
  }

  async function runSingleCourse() {
    const course = parseCourseFilter($("courseFilter")?.value || "");
    if (!course) {
      setStatus("Renseigne une course au format R1C1.", true);
      return;
    }
    if (!currentAnalysisJson || !Array.isArray(currentAnalysisJson.data)) {
      setStatus("Charge l’analyse du jour avant de sélectionner une course.", true);
      return;
    }
    const sourceItem = currentAnalysisJson.data.find(item => {
      return String(item.reunion) === String(course.reunion) && String(item.course) === String(course.course);
    });
    const sourceItemDecorated = sourceItem
      ? decorateAnalysisItem(sourceItem, fromJJMMAAAA(currentAnalysisJson.date))
      : null;
    if (!canAnalyzeReunionNow(sourceItemDecorated)) {
      setStatus("Analyse disponible uniquement à D-5 de la première course de la réunion.", true);
      return;
    }
    lockBtns(true);
    $("results").innerHTML = "";
    $("summary").style.display = "none";
    try {
      setStatus(`Analyse ciblée de ${course.key}...`);
      const ok = await runAnalysis(currentIso);
      if (!ok) {
        return;
      }
      const preparedItem = currentAnalysisJson && Array.isArray(currentAnalysisJson.data)
        ? currentAnalysisJson.data.find(item => String(item.reunion) === String(course.reunion) && String(item.course) === String(course.course))
        : null;
      const preparedItemDecorated = preparedItem
        ? decorateAnalysisItem(preparedItem, fromJJMMAAAA(currentAnalysisJson.date))
        : null;
      if (preparedItemDecorated && preparedItemDecorated.selection && canAnalyzeCourseNow(preparedItemDecorated)) {
        await preparePmuTicket(preparedItemDecorated);
      }
      pushJournal(`Mode course unique appliqué sur ${course.key}.`, "ok");
      setResultState(`Course unique ${course.key}`, "ok");
    } finally {
      lockBtns(false);
    }
  }

  async function preparePmuTicket(item) {
    if (!item || !item.selection) {
      throw new Error("Sélection indisponible pour préparer le ticket.");
    }
    if (!canAnalyzeCourseNow(item)) {
      throw new Error("Préparation disponible uniquement à partir de D-5.");
    }
    setStatus(`Préparation du ticket PMU pour R${item.reunion}C${item.course}...`);
    const url = new URL("http://127.0.0.1:8787/prepare-ticket");
    url.searchParams.set("reunion", `R${item.reunion}`);
    url.searchParams.set("course", `C${item.course}`);
    url.searchParams.set("horse", item.selection.num);
    url.searchParams.set("stake", item.selection.mise ?? 1);
    url.searchParams.set("capital", getDayBankroll().toString());
    if (currentAnalysisJson && currentAnalysisJson.date) {
      url.searchParams.set("date", String(currentAnalysisJson.date));
    }
    url.searchParams.set("_ts", Date.now().toString());
    const response = await fetch(url.toString(), {
      method: "GET",
      cache: "no-store",
      headers: {
        "Cache-Control": "no-cache",
        "Pragma": "no-cache",
      },
    });
    const text = await response.text();
    const json = safeParseJson(text);
    if (!json) {
      throw new Error("Réponse non JSON du préparateur PMU.");
    }
    if (!json.success) {
      throw new Error(json.message || "Echec de préparation du ticket.");
    }
    const ticketStake = json.resolved_stake || json.stake || item.selection.mise || 1;
    const ticketLabel = `R${item.reunion}C${item.course} - N°${item.selection.num} ${item.selection.nom} - ${ticketStake} €`;
    pushJournal(`Ticket PMU préparé : ${ticketLabel}.`, "ok");
    if (json.push_sent) {
      pushJournal(`Push téléphone envoyé via ${json.push_provider || "ntfy"}.`, "ok");
    } else if (json.push_error) {
      pushJournal(`Push non envoyé : ${json.push_error}`, "warn");
    }
    await refreshWatcherHealth();
    setResultState("Ticket PMU préparé", "ok");
    setStatus(json.message || `Ticket PMU préparé : ${ticketLabel}`);
    await refreshLiveTicketSnapshot(currentAnalysisJson?.date ? fromJJMMAAAA(currentAnalysisJson.date) : currentIso, getDayBankroll());
    return json;
  }

  function setTopTabState() {
    const analysisTab = $("btnAnalysisTab");
    const fullDayTab = $("btnFullDayCourses");
    const versionBadge = $("versionBadge");
    if (analysisTab) analysisTab.classList.toggle("active", !fullDayCoursesOpen);
    if (fullDayTab) fullDayTab.classList.toggle("active", fullDayCoursesOpen);
    if (versionBadge) {
      versionBadge.classList.toggle("is-active", fullDayCoursesOpen);
      versionBadge.textContent = fullDayCoursesOpen
        ? "Vue complète active"
        : "Vue complète triée par réunion et filtrable";
    }
  }

  async function refreshFullDayCourses(dateIso = null) {
    const iso = dateIso || currentIso;
    const date = toJJMMAAAA(iso);
    const json = await callScript("query_day_full.php", { date });
    currentFullDayJson = json;
    if (fullDayCoursesOpen && currentAnalysisJson) {
      renderAnalysisDashboard();
    } else if (!currentAnalysisJson) {
      $("results").innerHTML = renderFullDayCoursesSection();
    }
    if (fullDayCoursesOpen) {
      focusFullDaySection();
    }
    return json;
  }

  function closeFullDayCoursesView() {
    if (!fullDayCoursesOpen && !currentFullDayJson) return;
    fullDayCoursesOpen = false;
    currentFullDayJson = null;
    setTopTabState();
  }

  async function loadFullDayCourses() {
    const iso = currentIso;
    const date = toJJMMAAAA(iso);
    fullDayCoursesFilter = "all";
    setStatus("Chargement de toutes les courses du jour...");
    const json = await callScript("query_day_full.php", { date });
    currentFullDayJson = json;
    fullDayCoursesOpen = true;
    setTopTabState();
    if (currentAnalysisJson) {
      renderAnalysisDashboard();
    } else {
      $("results").innerHTML = renderFullDayCoursesSection();
    }
    focusFullDaySection();
    pushJournal(`Vue complète chargée : ${json.courses_count || 0} course(s) pour ${json.date}.`, "ok");
    return json;
  }

  async function toggleFullDayCourses() {
    if (fullDayCoursesOpen) {
      fullDayCoursesOpen = false;
      setTopTabState();
      if (currentAnalysisJson) {
        renderAnalysisDashboard();
      } else {
        renderDashboardPlaceholder();
      }
      pushJournal("Vue complète masquée.", "info");
      return;
    }
    await loadFullDayCourses();
  }

  // ── BATCH (plage de dates) ─────────────────────────────────────────────
  async function runBatch() {
    const from = $("dateFrom").value;
    const to   = $("dateTo").value;
    if (!from || !to || to < from) { setStatus("Plage de dates invalide.", true); return; }
    const n = daysBetween(from, to);
    if (n > 30) { setStatus("Plage trop grande (max 30 jours).", true); return; }

    lockBtns(true);
    $("results").innerHTML = "";
    $("batchResults").innerHTML = "";
    $("summary").style.display = "none";

    // Build day list
    const days = [];
    for (let i = 0; i < n; i++) days.push(addDays(from, i));

    // Render batch tracker
    $("batchResults").innerHTML = `
      <div class="batch-card">
        <h3>Traitement de la plage — ${days.length} jour(s)</h3>
        ${days.map(d => `
          <div class="batch-day" id="batch-${d}">
            <span class="d-label">${new Date(d+"T00:00:00").toLocaleDateString("fr-FR",{day:"2-digit",month:"2-digit"})}</span>
            <div class="d-bar"><div class="d-fill pending" id="fill-${d}"></div></div>
            <span class="d-status" id="status-${d}">En attente</span>
          </div>`).join("")}
      </div>`;

    let totalNet = 0, totalParis = 0;
    for (const day of days) {
      $(`fill-${day}`).className = "d-fill running";
      $(`status-${day}`).textContent = "En cours…";
      setStatus(`Traitement du ${new Date(day+"T00:00:00").toLocaleDateString("fr-FR")}…`);
      try {
        await runPipeline(day);
        await runAnalysis(day);
        const pnl = await runPnl(day);
        if (pnl) { totalNet += parseFloat(pnl.resultat_net_total || 0); totalParis += parseInt(pnl.nb_paris || 0); }
        $(`fill-${day}`).className = "d-fill done";
        $(`status-${day}`).textContent = pnl ? `${pnl.resultat_net_total} €` : "OK";
        $(`status-${day}`).style.color = "var(--green)";
      } catch {
        $(`fill-${day}`).className = "d-fill error";
        $(`status-${day}`).textContent = "Erreur";
        $(`status-${day}`).style.color = "var(--red)";
      }
    }

    setStatus(`Plage terminée — ${totalParis} paris, résultat net total : ${totalNet.toFixed(2)} €`);
    setResultState("Batch terminé", "ok");
    lockBtns(false);
  }

  document.addEventListener("click", event => {
    const filterBtn = event.target.closest("[data-course-filter]");
    if (filterBtn) {
      currentCourseFilter = filterBtn.getAttribute("data-course-filter");
      renderAnalysisDashboard();
      return;
    }
    const fullDayFilterBtn = event.target.closest("[data-full-day-filter]");
    if (fullDayFilterBtn) {
      fullDayCoursesFilter = fullDayFilterBtn.getAttribute("data-full-day-filter") || "all";
      if (currentAnalysisJson) {
        renderAnalysisDashboard();
      } else if (currentFullDayJson) {
        $("results").innerHTML = renderFullDayCoursesSection();
        focusFullDaySection();
      }
      return;
    }
    const toggleBtn = event.target.closest("[data-toggle-selected]");
    if (toggleBtn) {
      fullSelectionListOpen = !fullSelectionListOpen;
      renderAnalysisDashboard();
      return;
    }
    const fullDayToggle = event.target.closest("[data-toggle-full-day]");
    if (fullDayToggle) {
      toggleFullDayCourses().catch(err => alert(err.message));
      return;
    }
    const ticketBtn = event.target.closest("[data-open-ticket]");
    if (ticketBtn) {
      fullSelectionListOpen = true;
      currentCourseFilter = "all";
      renderAnalysisDashboard();
      const key = ticketBtn.getAttribute("data-open-ticket");
      const row = document.getElementById(`ticket-${key}`);
      if (row) {
        row.scrollIntoView({ behavior: "smooth", block: "center" });
        row.style.outline = "2px solid var(--accent)";
        setTimeout(() => { row.style.outline = ""; }, 1800);
        setStatus(`Ticket ciblé : ${key.replace("-", " ")}`);
      }
    }
    const selectBtn = event.target.closest("[data-select-course]");
    if (selectBtn) {
      const key = selectBtn.getAttribute("data-select-course");
      if (key) {
        $("courseFilter").value = key;
        setStatus(`Course sélectionnée : ${key}. Analyse autorisée à D-5 de la première course de la réunion.`);
        runSingleCourse().catch(err => alert(err.message));
      }
    }
    const prepareBtn = event.target.closest("[data-prepare-pmu]");
    if (prepareBtn) {
      const key = prepareBtn.getAttribute("data-prepare-pmu");
      const item = currentAnalysisJson && Array.isArray(currentAnalysisJson.data)
        ? currentAnalysisJson.data.find(row => `R${row.reunion}C${row.course}` === key)
        : null;
      if (!item) {
        alert("Course introuvable pour la préparation du ticket.");
        return;
      }
      preparePmuTicket(item).catch(err => alert(err.message));
    }
  });

  renderSystemState();
  renderJournal();
  renderSummaryCards();
  renderDashboardPlaceholder();
  refreshWatcherHealth().catch(() => {});
</script>
