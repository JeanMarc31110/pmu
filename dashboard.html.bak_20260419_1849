    @media (max-width: 540px) {
      #summary { grid-template-columns: 1fr; }
      .quick-btns { grid-template-columns: 1fr 1fr; }
      .top-tabs { gap: 8px; }
      .top-tab { font-size: 0.75rem; padding: 8px 10px; }
      .action-btn { padding: 12px 14px; font-size: 0.84rem; }
      .card-body { padding: 14px 14px; }
      .sidebar { gap: 12px; }
      .hero-card h2 { font-size: 1.22rem; }
      .hero-card p { font-size: 0.88rem; }
