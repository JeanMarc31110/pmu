<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PMU Moulinette</title>
  <style>
    :root {
      --bg: #f4f1ea;
      --panel: #fbf8f2;
      --card: #fffdf8;
      --border: #d8cfbf;
      --accent: #0f766e;
      --green: #2f855a;
      --red: #c53030;
      --orange: #c77d18;
      --text: #231c17;
      --muted: #786b5d;
      --radius: 16px;
      --shadow: 0 12px 28px rgba(52, 36, 18, 0.08);
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background:
        radial-gradient(circle at top left, rgba(199,125,24,0.10), transparent 28%),
        radial-gradient(circle at top right, rgba(15,118,110,0.10), transparent 24%),
        var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── HEADER ── */
    header {
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      padding: 18px 32px;
      box-shadow: var(--shadow);
    }
    header h1 { font-size: 1.45rem; font-weight: 700; color: var(--text); }
    header p  { font-size: 0.82rem; color: var(--muted); margin-top: 3px; }

    /* ── LAYOUT ── */
    .layout {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 20px;
      padding: 24px;
      max-width: 1400px;
      margin: 0 auto;
    }

    /* ── SIDEBAR ── */
    .sidebar { display: flex; flex-direction: column; gap: 16px; }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .card-title {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      color: var(--muted);
      padding: 14px 18px 10px;
      border-bottom: 1px solid var(--border);
    }
    .card-body { padding: 16px 18px; }

    /* ── DATE PICKER ── */
    .date-nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .date-nav button {
      background: #fff;
      border: 1px solid var(--border);
      color: var(--text);
      width: 32px; height: 32px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 1rem;
      display: flex; align-items: center; justify-content: center;
      transition: background 0.15s;
    }
    .date-nav button:hover { background: var(--border); }
    #selected-date-label { font-size: 0.92rem; font-weight: 700; color: var(--text); }

    input[type="date"] {
      width: 100%;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 0.9rem;
      padding: 9px 12px;
      cursor: pointer;
      outline: none;
      margin-bottom: 12px;
    }
    input[type="date"]:focus { border-color: var(--accent); }
    input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.6); cursor: pointer; }

    /* ── QUICK DATES ── */
    .quick-btns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      margin-bottom: 0;
    }
    .quick-btn {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 0.78rem;
      padding: 7px 6px;
      cursor: pointer;
      text-align: center;
      transition: all 0.15s;
      font-weight: 500;
    }
    .quick-btn:hover   { border-color: var(--accent); color: var(--accent); }
    .quick-btn.active  { border-color: var(--accent); background: rgba(15,118,110,0.10); color: var(--accent); }

    /* ── ACTION BUTTONS ── */
    .action-btn {
      width: 100%;
      border: none;
      border-radius: 10px;
      padding: 13px 16px;
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
      margin-bottom: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .action-btn:last-child { margin-bottom: 0; }
    .action-btn:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
    .action-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .btn-import  { background: #174e9e; color: #fff; }
    .btn-analyse { background: #dff5ea; color: #17462f; border: 1px solid rgba(47,133,90,0.18); }
    .btn-gains   { background: #f9ead7; color: #6a3d00; border: 1px solid rgba(199,125,24,0.18); }
    .btn-all     { background: linear-gradient(135deg, #0f766e, #c77d18); color: #fff; }

    /* ── MULTI-DATE ── */
    .multi-toggle {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 12px;
      cursor: pointer;
    }
    .multi-toggle input { accent-color: var(--accent); cursor: pointer; }
    .multi-section { display: none; }
    .multi-section.visible { display: block; }
    .multi-row { display: flex; gap: 8px; align-items: center; margin-bottom: 10px; }
    .multi-row label { font-size: 0.78rem; color: var(--muted); min-width: 34px; }
    .multi-row input[type="date"] { margin-bottom: 0; flex: 1; }
    .multi-info {
      font-size: 0.75rem;
      color: var(--muted);
      margin-bottom: 10px;
      line-height: 1.4;
    }

    /* ── STATUS ── */
    #statusBox {
      font-size: 0.78rem;
      color: var(--muted);
      padding: 10px 14px;
      background: #fff;
      border-radius: 8px;
      min-height: 36px;
      line-height: 1.5;
      border: 1px solid var(--border);
    }

    /* ── PROGRESS ── */
    .progress-wrap { margin-bottom: 6px; display: none; }
    .progress-bar {
      height: 4px;
      background: var(--border);
      border-radius: 4px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: var(--accent);
      border-radius: 4px;
      transition: width 0.4s ease;
      width: 0%;
    }
    .progress-label {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 5px;
      text-align: right;
    }

    /* ── MAIN CONTENT ── */
    .main-col { display: flex; flex-direction: column; gap: 16px; }
    .hero-card {
      background: linear-gradient(135deg, rgba(255,255,255,.78), rgba(255,248,239,.92));
      border: 1px solid var(--border);
      border-radius: 24px;
      box-shadow: var(--shadow);
      padding: 24px 26px;
    }
    .hero-kicker {
      font-size: .76rem;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: var(--accent);
      font-weight: 700;
      margin-bottom: 8px;
    }
    .hero-card h2 {
      font-size: 1.7rem;
      line-height: 1.08;
      margin-bottom: 8px;
    }
    .hero-card p {
      color: var(--muted);
      font-size: .94rem;
      max-width: 760px;
      line-height: 1.5;
    }
    .main-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(300px, .8fr);
      gap: 16px;
      align-items: start;
    }
    .primary-col,
    .side-col {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ── SUMMARY GRID ── */
    #summary {
      display: none;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }
    .box {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px 16px;
      box-shadow: var(--shadow);
    }
    .box .k { font-size: 0.72rem; color: var(--muted); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.6px; }
    .box .v { font-size: 1.25rem; font-weight: 700; color: var(--text); }

    /* ── RESULTS ── */
    #results { display: flex; flex-direction: column; gap: 12px; }

    .result-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .result-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 18px;
      border-bottom: 1px solid var(--border);
    }
    .result-head .title { font-size: 0.9rem; font-weight: 600; color: var(--text); }
    .result-card .status { padding: 12px 18px; font-size: 0.82rem; color: var(--muted); line-height: 1.6; }
    .result-card .meta {
      display: flex; gap: 8px; flex-wrap: wrap;
      padding: 12px 18px;
      border-bottom: 1px solid var(--border);
    }
    .result-card .meta .box { padding: 8px 12px; flex: 1; min-width: 100px; }
    .result-card .meta .box .v { font-size: 0.95rem; }

    /* ── PILL ── */
    .pill {
      display: inline-block;
      padding: 3px 12px;
      border-radius: 20px;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .pill.ok   { background: rgba(62,207,142,0.15); color: var(--green); }
    .pill.warn { background: rgba(246,173,85,0.15);  color: var(--orange); }
    .pill.no   { background: rgba(245,101,101,0.15); color: var(--red); }

    .section-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 18px 20px 12px;
      border-bottom: 1px solid rgba(216,207,191,.8);
    }
    .section-head h2 {
      font-size: 1rem;
      color: var(--text);
      margin-bottom: 3px;
    }
    .section-head p {
      font-size: 0.82rem;
      color: var(--muted);
    }
    .ghost-btn {
      background: #fff;
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 999px;
      padding: 9px 14px;
      font-size: 0.8rem;
      font-weight: 700;
      cursor: pointer;
    }
    .chip-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      padding: 14px 20px 0;
    }
    .chip-filter {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 7px 12px;
      font-size: 0.76rem;
      font-weight: 700;
      color: var(--muted);
      cursor: pointer;
    }
    .chip-filter.active {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(15,118,110,0.08);
    }
    .urgent-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 12px;
      padding: 18px 20px 20px;
    }
    .urgent-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
    }
    .urgent-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 8px;
    }
    .urgent-title { font-size: 0.92rem; font-weight: 700; color: var(--text); }
    .urgent-sub { font-size: 0.8rem; color: var(--muted); margin-top: 3px; }
    .count-badge {
      background: rgba(199,125,24,0.12);
      color: var(--orange);
      border-radius: 999px;
      padding: 6px 10px;
      font-size: 0.74rem;
      font-weight: 700;
      white-space: nowrap;
    }
    .ticket-btn {
      margin-top: 12px;
      background: rgba(15,118,110,0.10);
      color: var(--accent);
      border: 1px solid rgba(15,118,110,0.18);
      border-radius: 12px;
      padding: 8px 12px;
      font-size: 0.78rem;
      font-weight: 700;
      cursor: default;
      display: inline-block;
    }
    .empty-state {
      padding: 18px 20px 20px;
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.5;
    }
    .muted-note {
      padding: 0 20px 18px;
      color: var(--muted);
      font-size: 0.78rem;
    }
    .state-stack {
      display: flex;
      flex-direction: column;
      gap: 12px;
      padding: 18px 20px 20px;
    }
    .state-item {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px 14px;
    }
    .state-item strong {
      display: block;
      font-size: 0.88rem;
      margin-bottom: 3px;
      color: var(--text);
    }
    .state-item span {
      color: var(--muted);
      font-size: 0.79rem;
      line-height: 1.45;
    }
    .journal-box {
      background: #1f1b18;
      color: #f6efe6;
      border-radius: 18px;
      margin: 0 20px 20px;
      padding: 16px;
      min-height: 260px;
      font-family: Consolas, monospace;
      font-size: 0.8rem;
      line-height: 1.65;
      overflow: auto;
    }
    .journal-line {
      margin-bottom: 8px;
      color: #e9dccb;
    }
    .journal-line .ts { color: #8cc9c3; }
    .journal-line.ok { color: #a7efc0; }
    .journal-line.warn { color: #f2c078; }
    .journal-line.err { color: #f3a0a0; }

    /* ── RESULT STATE HEADER ── */
    #resultState { display: inline-block; }

    /* ── TABLE ── */
    .table-wrap { overflow-x: auto; padding: 0 18px 16px; }
    table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    th {
      text-align: left; padding: 8px 12px;
      font-size: 0.7rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.7px;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }
    td { padding: 9px 12px; border-bottom: 1px solid rgba(0,0,0,0.05); }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(15,118,110,0.03); }

    /* ── BATCH PROGRESS ── */
    .batch-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px 18px;
    }
    .batch-card h3 { font-size: 0.85rem; font-weight: 600; margin-bottom: 12px; }
    .batch-day {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 7px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      font-size: 0.8rem;
    }
    .batch-day:last-child { border-bottom: none; }
    .batch-day .d-label { width: 90px; color: var(--muted); }
    .batch-day .d-bar { flex: 1; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
    .batch-day .d-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
    .batch-day .d-status { width: 80px; text-align: right; font-size: 0.72rem; }
    .d-fill.pending  { background: var(--border); width: 0%; }
    .d-fill.running  { background: var(--accent); width: 50%; animation: pulse-bar 1s infinite; }
    .d-fill.done     { background: var(--green); width: 100%; }
    .d-fill.error    { background: var(--red); width: 100%; }
    @keyframes pulse-bar { 0%,100%{opacity:1} 50%{opacity:0.5} }

    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; }
      #summary { grid-template-columns: repeat(2,1fr); }
      .main-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<header>
  <h1>PMU Moulinette</h1>
  <p>Flux du jour, analyse, départs imminents et lecture complète des courses sélectionnées.</p>
</header>

<div class="layout">

  <!-- ── SIDEBAR ── -->
  <div class="sidebar">

    <!-- Date picker -->
    <div class="card">
      <div class="card-title">Date</div>
      <div class="card-body">
        <div class="date-nav">
          <button id="btnPrev" title="Jour précédent">◀</button>
          <span id="selected-date-label">—</span>
          <button id="btnNext" title="Jour suivant">▶</button>
        </div>
        <input type="date" id="datepicker">
        <div class="quick-btns">
          <button class="quick-btn" data-offset="0">Aujourd'hui</button>
          <button class="quick-btn" data-offset="-1">Hier</button>
          <button class="quick-btn" data-offset="-2">Avant-hier</button>
          <button class="quick-btn" data-offset="-7">Il y a 7j</button>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="card">
      <div class="card-title">Actions</div>
      <div class="card-body">
        <button class="action-btn btn-all"     id="btnAll"     onclick="runAll()">Flux complet</button>
        <button class="action-btn btn-import"  id="btnImport"  onclick="runPipeline()">Préparer les données</button>
        <button class="action-btn btn-analyse" id="btnAnalyse" onclick="runAnalysis()">Lancer l’analyse</button>
        <button class="action-btn btn-gains"   id="btnGains"   onclick="runPnl()">Calculer les gains</button>
      </div>
    </div>

    <!-- Multi-dates -->
    <div class="card">
      <div class="card-title">Plage</div>
      <div class="card-body">
        <label class="multi-toggle">
          <input type="checkbox" id="multiToggle"> Activer le mode plage
        </label>
        <div class="multi-section" id="multiSection">
          <div class="multi-row">
            <label>Du</label>
            <input type="date" id="dateFrom">
          </div>
          <div class="multi-row">
            <label>Au</label>
            <input type="date" id="dateTo">
          </div>
          <div class="multi-info" id="multiInfo">Sélectionnez une plage pour voir le nombre de jours.</div>
          <button class="action-btn btn-all" id="btnBatch" onclick="runBatch()">Lancer la plage</button>
        </div>
      </div>
    </div>

    <!-- Status -->
    <div class="card">
      <div class="card-title">Statut</div>
      <div class="card-body" style="padding:12px 14px">
        <div class="progress-wrap" id="progressWrap">
          <div class="progress-bar"><div class="progress-fill" id="progressFill"></div></div>
          <div class="progress-label" id="progressLabel"></div>
        </div>
        <div id="statusBox">Prêt.</div>
      </div>
    </div>

  </div>

  <!-- ── MAIN ── -->
  <div class="main-col">
    <section class="hero-card">
      <div class="hero-kicker">Prévisualisation Validée</div>
      <h2>Départs dans 10 min, puis toutes les sélections du jour.</h2>
      <p>La page met en avant les courses imminentes, puis déroule la liste complète des courses sélectionnées avec un état système simple et un journal technique lisible.</p>
    </section>
    <div id="summary" style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0" id="resultHeader" style="display:none">
      <span id="resultState" class="pill warn">Aucune action</span>
    </div>
    <div class="main-grid">
      <div class="primary-col">
        <div id="results"></div>
        <div id="batchResults"></div>
      </div>
      <aside class="side-col">
        <section class="section-card">
          <div class="section-head">
            <div>
              <h2>État système</h2>
              <p>Lecture rapide de la journée en cours.</p>
            </div>
          </div>
          <div class="state-stack" id="stateSystem"></div>
        </section>
        <section class="section-card">
          <div class="section-head">
            <div>
              <h2>Journal</h2>
              <p>Étapes utiles et derniers retours du pipeline.</p>
            </div>
          </div>
          <div class="journal-box" id="journalBox"></div>
        </section>
      </aside>
    </div>
  </div>

</div>

<script>
  const $ = id => document.getElementById(id);
  const BASE_URL = window.location.origin + "/pmu";

  // ── FORMAT ──────────────────────────────────────────────────────────
  function toJJMMAAAA(dateStr) {
    // dateStr = "YYYY-MM-DD"
    const [y, m, d] = dateStr.split("-");
    return d + m + y;
  }
  function fromJJMMAAAA(s) {
    // s = "DDMMYYYY"
    return s.slice(4) + "-" + s.slice(2, 4) + "-" + s.slice(0, 2);
  }
  function labelDate(dateStr) {
    const d = new Date(dateStr + "T00:00:00");
    return d.toLocaleDateString("fr-FR", { weekday:"long", day:"2-digit", month:"long", year:"numeric" });
  }
  function isoToday() {
    return new Date().toISOString().slice(0, 10);
  }
  function addDays(iso, n) {
    const d = new Date(iso + "T00:00:00");
    d.setDate(d.getDate() + n);
    return d.toISOString().slice(0, 10);
  }
  function daysBetween(from, to) {
    return Math.round((new Date(to) - new Date(from)) / 86400000) + 1;
  }

  // ── DATE STATE ────────────────────────────────────────────────────────
  let currentIso = isoToday();

  function setDate(iso) {
    currentIso = iso;
    $("datepicker").value = iso;
    $("selected-date-label").textContent = labelDate(iso);
    // Update quick btn active state
    const today = isoToday();
    document.querySelectorAll(".quick-btn").forEach(btn => {
      const offset = parseInt(btn.dataset.offset);
      btn.classList.toggle("active", addDays(today, offset) === iso);
    });
  }

  // Init
  setDate(isoToday());

  // Date picker events
  $("datepicker").addEventListener("change", e => setDate(e.target.value));
  $("btnPrev").addEventListener("click", () => setDate(addDays(currentIso, -1)));
  $("btnNext").addEventListener("click", () => setDate(addDays(currentIso, +1)));

  document.querySelectorAll(".quick-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      setDate(addDays(isoToday(), parseInt(btn.dataset.offset)));
    });
  });

  // Multi-date toggle
  $("multiToggle").addEventListener("change", e => {
    $("multiSection").classList.toggle("visible", e.target.checked);
  });

  function updateMultiInfo() {
    const from = $("dateFrom").value;
    const to   = $("dateTo").value;
